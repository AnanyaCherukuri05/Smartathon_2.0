# Server configuration
PORT=5000

# MongoDB (optional)
# MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

# External APIs
WEATHER_API_KEY=
GEMINI_API_KEY=
AGMARKNET_API_KEY=

# Azure Translator (used for auto-translating UI strings)
# Create a Translator resource in Azure and set these:
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
# Optional override; default is Microsoft public endpoint:
# AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
